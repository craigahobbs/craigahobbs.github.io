function testColorRampRenderEditorTwoColors():
    ramp = {'name': 'Two', 'colors': [{'r': 0, 'g': 0, 'b': 0}, {'r': 255, 'g': 255, 'b': 255}]}
    unittestMockAll()
    testColorRampMockRender()
    colorRampRenderEditor({'hex': false}, ramp)
    calls = unittestMockEnd()

    # No delete buttons at the two-color minimum
    unittestDeepEqual(calls, [ \
        ['elementModelRender', [testColorRampMenuElements( \
            formsLinkButtonElements('Add', colorRampAddColor), 'Hex', '#var.vHex=true', \
            formsLinkElements('Title', "#var.vAction='editRampName'"), 'two.json', null)]], \
        ['elementModelRender', [testColorRampTableElements([ \
            testColorRampRowElements(0, '#000000', 'rgb(0, 0, 0)', 0, 0, 0, null), \
            testColorRampRowElements(1, '#ffffff', 'rgb(255, 255, 255)', 255, 255, 255, null) \
        ])]] \
    ])
endfunction
unittestRunTest('testColorRampRenderEditorTwoColors')


function testColorRampRenderEditorHex():
    ramp = {'name': 'Two', 'colors': [{'r': 0, 'g': 128, 'b': 255}, {'r': 255, 'g': 255, 'b': 255}]}
    unittestMockAll()
    testColorRampMockRender()
    colorRampRenderEditor({'hex': true}, ramp)
    calls = unittestMockEnd()

    # The R/G/B inputs show two-digit hex values and the mode toggle shows "Dec"
    unittestDeepEqual(calls, [ \
        ['elementModelRender', [testColorRampMenuElements( \
            formsLinkButtonElements('Add', colorRampAddColor), 'Dec', '#var=', \
            formsLinkElements('Title', "#var.vAction='editRampName'"), 'two.json', null)]], \
        ['elementModelRender', [testColorRampTableElements([ \
            testColorRampRowElements(0, '#0080ff', 'rgb(0, 128, 255)', '00', '80', 'ff', null), \
            testColorRampRowElements(1, '#ffffff', 'rgb(255, 255, 255)', 'ff', 'ff', 'ff', null) \
        ])]] \
    ])
endfunction
unittestRunTest('testColorRampRenderEditorHex')


function testColorRampRenderEditorManyColors():
    color = {'r': 16, 'g': 32, 'b': 48}
    ramp = {'name': 'Many', 'colors': [color, color, color, color, color, color, color]}
    unittestMockAll()
    testColorRampMockRender()
    colorRampRenderEditor({'hex': false}, ramp)
    calls = unittestMockEnd()

    # There is no maximum color count - "Add" remains an active button
    rows = []
    ixColor = 0
    while ixColor < arrayLength(objectGet(ramp, 'colors')):
        arrayPush(rows, testColorRampRowElements(ixColor, '#102030', 'rgb(16, 32, 48)', 16, 32, 48, \
            formsLinkButtonElements('Delete', colorRampDeleteColor)))
        ixColor = ixColor + 1
    endwhile
    unittestDeepEqual(calls, [ \
        ['elementModelRender', [testColorRampMenuElements( \
            formsLinkButtonElements('Add', colorRampAddColor), 'Hex', '#var.vHex=true', \
            formsLinkElements('Title', "#var.vAction='editRampName'"), 'many.json', null)]], \
        ['elementModelRender', [testColorRampTableElements(rows)]] \
    ])
endfunction
unittestRunTest('testColorRampRenderEditorManyColors')


function testColorRampRenderEditorEditName():
    ramp = {'name': 'Two', 'colors': [{'r': 0, 'g': 0, 'b': 0}, {'r': 255, 'g': 255, 'b': 255}]}
    unittestMockAll()
    testColorRampMockRender()
    colorRampRenderEditor({'hex': false, 'action': 'editRampName'}, ramp)
    calls = unittestMockEnd()

    # The name editor renders below the menu, "Title" is inactive text, and the input is focused
    unittestDeepEqual(calls, [ \
        ['elementModelRender', [testColorRampMenuElements( \
            formsLinkButtonElements('Add', colorRampAddColor), 'Hex', '#var.vHex=true', \
            {'text': 'Title'}, 'two.json', [ \
                {'html': 'p', 'elem': formsTextElements('colorRampName', 'Two', 50, colorRampUpdateName)}, \
                {'html': 'p', 'elem': [ \
                    formsLinkButtonElements('Update', colorRampUpdateName), \
                    {'text': ' | '}, \
                    formsLinkElements('Cancel', '#var=') \
                ]} \
            ])]], \
        ['elementModelRender', [testColorRampTableElements([ \
            testColorRampRowElements(0, '#000000', 'rgb(0, 0, 0)', 0, 0, 0, null), \
            testColorRampRowElements(1, '#ffffff', 'rgb(255, 255, 255)', 255, 255, 255, null) \
        ])]], \
        ['documentSetFocus', ['colorRampName']] \
    ])
endfunction
unittestRunTest('testColorRampRenderEditorEditName')


function testColorRampRenderEditorMenuBindings():
    args = {'hex': false}
    render = systemPartial(colorRampRenderEditor, args, colorRampCreateDefault())

    # The menu buttons must bind their own handlers with the render arguments
    testColorRampVerifyClick(render, 'Add', systemPartial(colorRampAddColor, args), null)
    testColorRampVerifyClick(render, 'Update', systemPartial(colorRampUpdate, args), null)
    testColorRampVerifyClick(render, 'Reset', systemPartial(colorRampReset, args), null)
endfunction
unittestRunTest('testColorRampRenderEditorMenuBindings')


function testColorRampRenderEditorDeleteBindings():
    args = {'hex': false}
    render = systemPartial(colorRampRenderEditor, args, colorRampCreateDefault())

    # Each row's Delete button must delete its own color index
    testColorRampVerifyClickN(render, 'Delete', 0, systemPartial(colorRampDeleteColor, args, 0), null)
    testColorRampVerifyClickN(render, 'Delete', 2, systemPartial(colorRampDeleteColor, args, 2), null)
endfunction
unittestRunTest('testColorRampRenderEditorDeleteBindings')


function testColorRampRenderEditorNameBindings():
    args = {'hex': false, 'action': 'editRampName'}
    render = systemPartial(colorRampRenderEditor, args, colorRampCreateDefault())
    data = {'documentInputValue': {'colorRampName': 'Renamed'}}

    # The menu Update button updates the colors; the name editor's Update button updates the name
    testColorRampVerifyClickN(render, 'Update', 0, systemPartial(colorRampUpdate, args), data)
    testColorRampVerifyClickN(render, 'Update', 1, colorRampUpdateName, data)
endfunction
unittestRunTest('testColorRampRenderEditorNameBindings')


