function testColorRampAddColor():
    unittestMockAll()
    localStorageClear()
    testColorRampMockRender()
    colorRampAddColor({'hex': false})
    calls = unittestMockEnd()

    # The new color is the rounded midpoint of the last two colors, and the application re-renders
    expectedRamp = objectCopy(colorRampCreateDefault())
    arrayPush(objectGet(expectedRamp, 'colors'), {'r': 52, 'g': 125, 'b': 70})
    expected = [ \
        ['localStorageClear', []], \
        ['localStorageSet', ['colorRamp', jsonStringify(expectedRamp)]] \
    ]
    arrayExtend(expected, testColorRampRenderCalls({'hex': false}, expectedRamp))
    unittestDeepEqual(calls, expected)
endfunction
unittestRunTest('testColorRampAddColor')


#
# colorRampUpdate
#


function testColorRampUpdate():
    unittestMockAll({'documentInputValue': { \
        'colorRampR0': '300', 'colorRampG0': '-5', 'colorRampB0': '128', \
        'colorRampR1': '10', 'colorRampG1': 'abc', 'colorRampB1': '20' \
    }})
    localStorageClear()
    testColorRampMockRender()
    colorRampUpdate({'hex': false})
    calls = unittestMockEnd()

    # Values are parsed and clamped; the color with missing inputs is unchanged
    expectedRamp = objectCopy(colorRampCreateDefault())
    arraySet(objectGet(expectedRamp, 'colors'), 0, {'r': 255, 'g': 0, 'b': 128})
    arraySet(objectGet(expectedRamp, 'colors'), 1, {'r': 10, 'g': 0, 'b': 20})
    expected = [ \
        ['localStorageClear', []], \
        ['documentInputValue', ['colorRampR0']], \
        ['documentInputValue', ['colorRampG0']], \
        ['documentInputValue', ['colorRampB0']], \
        ['documentInputValue', ['colorRampR1']], \
        ['documentInputValue', ['colorRampG1']], \
        ['documentInputValue', ['colorRampB1']], \
        ['documentInputValue', ['colorRampR2']], \
        ['documentInputValue', ['colorRampG2']], \
        ['documentInputValue', ['colorRampB2']], \
        ['documentInputValue', ['colorRampR3']], \
        ['documentInputValue', ['colorRampG3']], \
        ['documentInputValue', ['colorRampB3']], \
        ['documentInputValue', ['colorRampR4']], \
        ['documentInputValue', ['colorRampG4']], \
        ['documentInputValue', ['colorRampB4']], \
        ['documentInputValue', ['colorRampR5']], \
        ['documentInputValue', ['colorRampG5']], \
        ['documentInputValue', ['colorRampB5']], \
        ['documentInputValue', ['colorRampR6']], \
        ['documentInputValue', ['colorRampG6']], \
        ['documentInputValue', ['colorRampB6']], \
        ['localStorageSet', ['colorRamp', jsonStringify(expectedRamp)]] \
    ]
    arrayExtend(expected, testColorRampRenderCalls({'hex': false}, expectedRamp))
    unittestDeepEqual(calls, expected)
endfunction
unittestRunTest('testColorRampUpdate')


function testColorRampUpdateHex():
    unittestMockAll({'documentInputValue': { \
        'colorRampR0': 'ff', 'colorRampG0': '0x80', 'colorRampB0': 'g', \
        'colorRampR1': '00', 'colorRampG1': '00', 'colorRampB1': '00', \
        'colorRampR2': 'X10', 'colorRampG2': '20', 'colorRampB2': '30' \
    }})
    localStorageClear()
    testColorRampMockRender()
    colorRampUpdate({'hex': true})
    calls = unittestMockEnd()

    # Hex values are parsed, with "0x"/"x" prefixes stripped and garbage parsed as zero
    expectedRamp = objectCopy(colorRampCreateDefault())
    arraySet(objectGet(expectedRamp, 'colors'), 0, {'r': 255, 'g': 128, 'b': 0})
    arraySet(objectGet(expectedRamp, 'colors'), 1, {'r': 0, 'g': 0, 'b': 0})
    arraySet(objectGet(expectedRamp, 'colors'), 2, {'r': 16, 'g': 32, 'b': 48})
    expected = [ \
        ['localStorageClear', []], \
        ['documentInputValue', ['colorRampR0']], \
        ['documentInputValue', ['colorRampG0']], \
        ['documentInputValue', ['colorRampB0']], \
        ['documentInputValue', ['colorRampR1']], \
        ['documentInputValue', ['colorRampG1']], \
        ['documentInputValue', ['colorRampB1']], \
        ['documentInputValue', ['colorRampR2']], \
        ['documentInputValue', ['colorRampG2']], \
        ['documentInputValue', ['colorRampB2']], \
        ['documentInputValue', ['colorRampR3']], \
        ['documentInputValue', ['colorRampG3']], \
        ['documentInputValue', ['colorRampB3']], \
        ['documentInputValue', ['colorRampR4']], \
        ['documentInputValue', ['colorRampG4']], \
        ['documentInputValue', ['colorRampB4']], \
        ['documentInputValue', ['colorRampR5']], \
        ['documentInputValue', ['colorRampG5']], \
        ['documentInputValue', ['colorRampB5']], \
        ['documentInputValue', ['colorRampR6']], \
        ['documentInputValue', ['colorRampG6']], \
        ['documentInputValue', ['colorRampB6']], \
        ['localStorageSet', ['colorRamp', jsonStringify(expectedRamp)]] \
    ]
    arrayExtend(expected, testColorRampRenderCalls({'hex': true}, expectedRamp))
    unittestDeepEqual(calls, expected)
endfunction
unittestRunTest('testColorRampUpdateHex')


#
# colorRampParseValue
#


function testColorRampParseValue():
    unittestEqual(colorRampParseValue('42', false), 42)
    unittestEqual(colorRampParseValue(' 42 ', false), 42)
    unittestEqual(colorRampParseValue('-5', false), -5)
    unittestEqual(colorRampParseValue('abc', false), 0)
    unittestEqual(colorRampParseValue('ff', true), 255)
    unittestEqual(colorRampParseValue('0xff', true), 255)
    unittestEqual(colorRampParseValue('X80', true), 128)
    unittestEqual(colorRampParseValue('zz', true), 0)
endfunction
unittestRunTest('testColorRampParseValue')


#
# colorRampUpdateName
#


function testColorRampUpdateName():
    unittestMockAll({'documentInputValue': {'colorRampName': '  New Name  '}})
    localStorageClear()
    colorRampUpdateName()
    calls = unittestMockEnd()

    # The trimmed name is saved and the "action" argument is removed
    expectedRamp = objectAssign(colorRampCreateDefault(), {'name': 'New Name'})
    unittestDeepEqual(calls, [ \
        ['localStorageClear', []], \
        ['documentInputValue', ['colorRampName']], \
        ['localStorageSet', ['colorRamp', jsonStringify(expectedRamp)]], \
        ['windowSetLocation', ['#var=']] \
    ])
endfunction
unittestRunTest('testColorRampUpdateName')


function testColorRampUpdateNameEmpty():
    unittestMockAll({'documentInputValue': {'colorRampName': '   '}})
    localStorageClear()
    colorRampUpdateName()
    calls = unittestMockEnd()

    # No save, but the "action" argument is still removed
    unittestDeepEqual(calls, [ \
        ['localStorageClear', []], \
        ['documentInputValue', ['colorRampName']], \
        ['windowSetLocation', ['#var=']] \
    ])
endfunction
unittestRunTest('testColorRampUpdateNameEmpty')


#
# colorRampDeleteColor
#


function testColorRampDeleteColor():
    unittestMockAll()
    localStorageClear()
    testColorRampMockRender()
    colorRampDeleteColor({'hex': false}, 1)
    calls = unittestMockEnd()

    # The middle color is deleted and the application re-renders
    expectedRamp = objectCopy(colorRampCreateDefault())
    arrayDelete(objectGet(expectedRamp, 'colors'), 1)
    expected = [ \
        ['localStorageClear', []], \
        ['localStorageSet', ['colorRamp', jsonStringify(expectedRamp)]] \
    ]
    arrayExtend(expected, testColorRampRenderCalls({'hex': false}, expectedRamp))
    unittestDeepEqual(calls, expected)
endfunction
unittestRunTest('testColorRampDeleteColor')


function testColorRampDeleteColorMin():
    systemGlobalSet('testColorRampStorage', \
        jsonStringify({'name': 'Two', 'colors': [{'r': 1, 'g': 1, 'b': 1}, {'r': 2, 'g': 2, 'b': 2}]}))
    unittestMockAll()
    unittestMockOne('localStorageGet', testColorRampStorageGet)
    colorRampDeleteColor({'hex': false}, 0)
    calls = unittestMockEnd()
    systemGlobalSet('testColorRampStorage', null)

    # No delete at the two-color minimum
    unittestDeepEqual(calls, [])
endfunction
unittestRunTest('testColorRampDeleteColorMin')


