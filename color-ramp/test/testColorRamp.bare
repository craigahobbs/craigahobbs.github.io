#
# colorRampToHex
#


function testColorRampToHex():
    unittestEqual(colorRampToHex(255, 0, 128), '#ff0080')
    unittestEqual(colorRampToHex(127.4, 127.5, 127.6), '#7f8080')
    unittestEqual(colorRampToHex(-3, 260, 0), '#00ff00')
endfunction
unittestRunTest('testColorRampToHex')


#
# colorRampByteToHex
#


function testColorRampByteToHex():
    unittestEqual(colorRampByteToHex(0), '00')
    unittestEqual(colorRampByteToHex(16), '10')
    unittestEqual(colorRampByteToHex(255), 'ff')
    unittestEqual(colorRampByteToHex(-5), '00')
    unittestEqual(colorRampByteToHex(300), 'ff')
endfunction
unittestRunTest('testColorRampByteToHex')
