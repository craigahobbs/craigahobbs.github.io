include <unittest.bare>
include <unittestMock.bare>

include '../colorRamp.bare'


#
# Test helpers
#
# Tests that touch local storage call localStorageClear() right after unittestMockAll() and
# assert the recorded ['localStorageClear', []] entry. The clear is required because
# unittestMock.bare resets its state with a shallow objectCopy - the nested localStorage
# object is shared, so mocked saves would otherwise leak into later tests.
#


# Mock the runtime functions the render path depends on: a 23-pixel window and 1-pixel font
# size for a tiny, deterministic 19-column color ramp display, and a fixed object URL
function testColorRampMockRender():
    unittestMockOne('windowWidth', testColorRampWindowWidth)
    unittestMockOne('documentFontSize', testColorRampFontSize)
    unittestMockOne('windowURLObject', testColorRampURLObject)
endfunction

function testColorRampWindowWidth():
    return 23
endfunction

function testColorRampFontSize():
    return 1
endfunction

function testColorRampURLObject():
    return 'blob:mock'
endfunction


# localStorageGet mock that returns the "testColorRampStorage" global
function testColorRampStorageGet():
    return systemGlobalGet('testColorRampStorage')
endfunction


# sessionStorageGet mock that returns a focus ID
function testColorRampSessionGet():
    return 'colorRampR0'
endfunction


# Capture the mock call log of rendering the given ramp - the expected render tail of
# interaction-handler tests. Render correctness itself is anchored by testColorRampRender's
# explicit whole-log assertion.
function testColorRampRenderCalls(args, ramp):
    systemGlobalSet('testColorRampStorage', jsonStringify(ramp))
    unittestMockAll()
    testColorRampMockRender()
    unittestMockOne('localStorageGet', testColorRampStorageGet)
    colorRampRender(args)
    calls = unittestMockEnd()
    systemGlobalSet('testColorRampStorage', null)
    return calls
endfunction


#
# Shared button callback-binding test helpers
#
# The render tests assert each button carries a callback ('<function>'), but not WHICH
# handler or captured arguments it is bound to (every function serializes to the same
# '<function>' placeholder under unittestDeepEqual). These helpers pull the actual captured
# callback out of the recorded call log and invoke it, proving the binding (e.g. that a
# "Delete" button removes its own row and not another).
#


# Recursively find a labeled button's real click callback in a rendered element model
function testColorRampFindClick(model, text):
    type = systemType(model)
    if type == 'array':
        for item in model:
            found = testColorRampFindClick(item, text)
            if found != null:
                return found
            endif
        endfor
    elif type == 'object':
        elem = objectGet(model, 'elem')
        callback = objectGet(model, 'callback')
        if callback != null && systemType(elem) == 'object' && objectGet(elem, 'text') == text:
            return objectGet(callback, 'click')
        endif
        return testColorRampFindClick(elem, text)
    endif
    return null
endfunction


# Collect the real click callbacks of every labeled button matching text, in document order.
# Used to disambiguate repeated labels (e.g. the three per-row "Delete" buttons).
function testColorRampFindClicks(model, text, result):
    type = systemType(model)
    if type == 'array':
        for item in model:
            testColorRampFindClicks(item, text, result)
        endfor
    elif type == 'object':
        elem = objectGet(model, 'elem')
        callback = objectGet(model, 'callback')
        if callback != null && systemType(elem) == 'object' && objectGet(elem, 'text') == text:
            arrayPush(result, objectGet(callback, 'click'))
        endif
        testColorRampFindClicks(elem, text, result)
    endif
    return result
endfunction


# Assert that invoking actualFn produces the same recorded call log as invoking expectedFn
# (each under fresh mocks from data). Proves a captured button callback is bound to the
# intended handler and arguments.
function testColorRampSameEffect(actualFn, expectedFn, data):
    unittestMockAll(data)
    localStorageClear()
    testColorRampMockRender()
    expectedFn()
    expected = unittestMockEnd()
    unittestMockAll(data)
    localStorageClear()
    testColorRampMockRender()
    actualFn()
    unittestDeepEqual(unittestMockEnd(), expected)
endfunction


# Render via renderFn, find the labeled button in the recorded call log, then verify its
# binding with testColorRampSameEffect
function testColorRampVerifyClick(renderFn, text, expectedFn, data):
    unittestMockAll(data)
    testColorRampMockRender()
    renderFn()
    found = testColorRampFindClick(unittestMockEnd(), text)
    testColorRampSameEffect(found, expectedFn, data)
endfunction


# Like testColorRampVerifyClick but selects the ix-th button matching text
function testColorRampVerifyClickN(renderFn, text, ix, expectedFn, data):
    unittestMockAll(data)
    testColorRampMockRender()
    renderFn()
    found = arrayGet(testColorRampFindClicks(unittestMockEnd(), text, []), ix)
    testColorRampSameEffect(found, expectedFn, data)
endfunction


#
# Expected element-model helpers
#


# The editor table header row element model
testColorRampHeaderElements = { \
    'html': 'tr', \
    'elem': [ \
        {'html': 'th', 'elem': {'text': 'Swatch'}}, \
        {'html': 'th', 'elem': {'text': 'Hex'}}, \
        {'html': 'th', 'elem': {'text': 'Decimal'}}, \
        {'html': 'th', 'elem': {'text': 'R'}}, \
        {'html': 'th', 'elem': {'text': 'G'}}, \
        {'html': 'th', 'elem': {'text': 'B'}}, \
        {'html': 'th', 'elem': {'text': 'Action'}} \
    ] \
}


# An editor table color-row element model. rValue/gValue/bValue are the input display
# values (decimal numbers or two-digit hex strings). deleteElem is the "Delete" button
# element model, or null below the three-color minimum.
function testColorRampRowElements(index, hexColor, decimalText, rValue, gValue, bValue, deleteElem):
    return { \
        'html': 'tr', \
        'elem': [ \
            { \
                'html': 'td', \
                'attr': {'style': 'vertical-align: middle;'}, \
                'elem': { \
                    'html': 'div', \
                    'attr': { \
                        'style': 'width: 50px; height: 30px; background-color: ' + hexColor + '; border: 1px solid black;' \
                    } \
                } \
            }, \
            {'html': 'td', 'elem': {'text': hexColor}}, \
            {'html': 'td', 'elem': {'text': decimalText}}, \
            {'html': 'td', 'elem': formsTextElements('colorRampR' + index, rValue, 6, colorRampUpdate)}, \
            {'html': 'td', 'elem': formsTextElements('colorRampG' + index, gValue, 6, colorRampUpdate)}, \
            {'html': 'td', 'elem': formsTextElements('colorRampB' + index, bValue, 6, colorRampUpdate)}, \
            {'html': 'td', 'elem': deleteElem} \
        ] \
    }
endfunction


# The editor table element model
function testColorRampTableElements(rows):
    tableRows = [testColorRampHeaderElements]
    arrayExtend(tableRows, rows)
    return { \
        'html': 'table', \
        'attr': {'style': 'border-collapse: collapse; margin: 10px 0;'}, \
        'elem': tableRows \
    }
endfunction


# The editor menu element model. addElem is the "Add" button or inactive text, modeText and
# modeHref are the hex/decimal toggle link, titleElem is the "Title" link or inactive text,
# and editorElems is the ramp-name editor element model array or null.
function testColorRampMenuElements(addElem, modeText, modeHref, titleElem, downloadFilename, editorElems):
    return { \
        'html': 'p', \
        'elem': [ \
            addElem, \
            {'text': ' | '}, \
            formsLinkButtonElements('Update', colorRampUpdate), \
            {'text': ' | '}, \
            formsLinkElements(modeText, modeHref), \
            {'text': ' | '}, \
            titleElem, \
            {'text': ' | '}, \
            formsLinkButtonElements('Reset', colorRampReset), \
            {'text': ' | '}, \
            { \
                'html': 'a', \
                'attr': {'href': 'blob:mock', 'download': downloadFilename}, \
                'elem': {'text': 'Download'} \
            }, \
            editorElems \
        ] \
    }
endfunction


# A color ramp display run rectangle element model
function testColorRampRectElements(fill, x, width):
    return { \
        'svg': 'rect', \
        'attr': { \
            'fill': fill, \
            'height': 99, \
            'rx': null, \
            'ry': null, \
            'stroke': 'none', \
            'stroke-dasharray': 'none', \
            'stroke-width': '0.00000000', \
            'width': width, \
            'x': x, \
            'y': 0.5 \
        } \
    }
endfunction


# The color ramp display element model - the white background plus the given run rectangles
function testColorRampSvgElements(runs):
    rects = [ \
        { \
            'svg': 'rect', \
            'attr': { \
                'fill': 'white', \
                'height': 100, \
                'rx': null, \
                'ry': null, \
                'stroke': 'none', \
                'stroke-dasharray': 'none', \
                'stroke-width': '0.00000000', \
                'width': 20, \
                'x': 0, \
                'y': 0 \
            } \
        } \
    ]
    arrayExtend(rects, runs)
    return { \
        'html': 'p', \
        'elem': { \
            'svg': 'svg', \
            'attr': {'width': 20, 'height': 100}, \
            'elem': rects \
        } \
    }
endfunction


# One single-pixel run rectangle per fill, for gradients with a distinct color per column
function testColorRampSvgGradientElements(fills):
    runs = []
    for fill, ixFill in fills:
        arrayPush(runs, testColorRampRectElements(fill, 0.5 + ixFill, 1))
    endfor
    return testColorRampSvgElements(runs)
endfunction


# The default ramp's 19 interpolated column colors at the mocked display size
testColorRampDefaultFills = [ \
    '#a3123a', '#b8213d', '#ce3040', '#e33f43', '#ea5550', '#f16b5e', '#f8816b', \
    '#ea9e88', '#dcbaa6', '#ced7c3', '#b0cda4', '#91c486', '#73ba67', '#63ac5f', \
    '#549f56', '#44914e', '#398448', '#2f7643', '#24693d' \
]


#
# colorRampMain
#


async function testColorRampMain():
    unittestMockAll()
    localStorageClear()
    testColorRampMockRender()
    colorRampMain()
    calls = unittestMockEnd()

    # The default ramp renders and the resize handler is set
    expected = [['localStorageClear', []]]
    arrayExtend(expected, testColorRampRenderCalls({'hex': false}, colorRampCreateDefault()))
    arrayPush(expected, ['windowSetResize', [colorRampRender]])
    unittestDeepEqual(calls, expected)
endfunction
unittestRunTest('testColorRampMain')


async function testColorRampMainModel():
    systemGlobalSet('vModel', true)
    unittestMockAll()
    colorRampMain()
    calls = unittestMockEnd()
    systemGlobalSet('vModel', null)

    # The documentation page renders instead of the application
    unittestDeepEqual(calls, [ \
        ['markdownPrint', ['[Home](#var=)']], \
        ['markdownPrint', [schemaDocMarkdown(colorRampTypes, 'ColorRamp')]] \
    ])
endfunction
unittestRunTest('testColorRampMainModel')


async function testColorRampMainURL():
    ramp = {'name': 'Fetched', 'colors': [{'r': 1, 'g': 2, 'b': 3}, {'r': 4, 'g': 5, 'b': 6}]}
    systemGlobalSet('vURL', 'test-ramp.json')
    unittestMockAll({'systemFetch': {'test-ramp.json': jsonStringify(ramp)}})
    localStorageClear()
    colorRampMain()
    calls = unittestMockEnd()
    systemGlobalSet('vURL', null)

    # The fetched ramp is saved and the URL argument is removed
    unittestDeepEqual(calls, [ \
        ['localStorageClear', []], \
        ['systemFetch', ['test-ramp.json']], \
        ['localStorageSet', ['colorRamp', jsonStringify(ramp)]], \
        ['windowSetLocation', ['#var=']] \
    ])
endfunction
unittestRunTest('testColorRampMainURL')


async function testColorRampMainURLError():
    systemGlobalSet('vURL', 'missing.json')
    unittestMockAll()
    colorRampMain()
    calls = unittestMockEnd()
    systemGlobalSet('vURL', null)

    # The fetch fails and the error message renders
    unittestDeepEqual(calls, [ \
        ['systemFetch', ['missing.json']], \
        ['markdownPrint', ['**ERROR:** Failed to load "missing.json"']] \
    ])
endfunction
unittestRunTest('testColorRampMainURLError')


#
# colorRampRender
#


function testColorRampRender():
    unittestMockAll()
    localStorageClear()
    testColorRampMockRender()
    colorRampRender({'hex': false})
    calls = unittestMockEnd()

    unittestDeepEqual(calls, [ \
        ['localStorageClear', []], \
        ['documentSetTitle', ['Color Ramp']], \
        ['markdownPrint', [ \
            '# Color Ramp', \
            '', \
            'A tool for creating and editing color gradients.', \
            '', \
            '[Color Ramp Library](index.html#url=colorRampLibrary.md)', \
            '', \
            '## Red\\-Green Diverging' \
        ]], \
        ['elementModelRender', [testColorRampSvgGradientElements(testColorRampDefaultFills)]], \
        ['elementModelRender', [testColorRampMenuElements( \
            formsLinkButtonElements('Add', colorRampAddColor), 'Hex', '#var.vHex=true', \
            formsLinkElements('Title', "#var.vAction='editRampName'"), 'red-green-diverging.json', null)]], \
        ['elementModelRender', [testColorRampTableElements([ \
            testColorRampRowElements(0, '#a3123a', 'rgb(163, 18, 58)', 163, 18, 58, \
                formsLinkButtonElements('Delete', colorRampDeleteColor)), \
            testColorRampRowElements(1, '#e33f43', 'rgb(227, 63, 67)', 227, 63, 67, \
                formsLinkButtonElements('Delete', colorRampDeleteColor)), \
            testColorRampRowElements(2, '#f8816b', 'rgb(248, 129, 107)', 248, 129, 107, \
                formsLinkButtonElements('Delete', colorRampDeleteColor)), \
            testColorRampRowElements(3, '#ced7c3', 'rgb(206, 215, 195)', 206, 215, 195, \
                formsLinkButtonElements('Delete', colorRampDeleteColor)), \
            testColorRampRowElements(4, '#73ba67', 'rgb(115, 186, 103)', 115, 186, 103, \
                formsLinkButtonElements('Delete', colorRampDeleteColor)), \
            testColorRampRowElements(5, '#44914e', 'rgb(68, 145, 78)', 68, 145, 78, \
                formsLinkButtonElements('Delete', colorRampDeleteColor)), \
            testColorRampRowElements(6, '#24693d', 'rgb(36, 105, 61)', 36, 105, 61, \
                formsLinkButtonElements('Delete', colorRampDeleteColor)) \
        ])]] \
    ])
endfunction
unittestRunTest('testColorRampRender')


function testColorRampRenderFocus():
    unittestMockAll()
    localStorageClear()
    testColorRampMockRender()
    unittestMockOne('sessionStorageGet', testColorRampSessionGet)
    colorRampRender({'hex': false})
    calls = unittestMockEnd()

    # The focus is restored and the focus session key is removed
    expected = [['localStorageClear', []]]
    arrayExtend(expected, testColorRampRenderCalls({'hex': false}, colorRampCreateDefault()))
    arrayPush(expected, ['documentSetFocus', ['colorRampR0']])
    arrayPush(expected, ['sessionStorageRemove', ['colorRampFocus']])
    unittestDeepEqual(calls, expected)
endfunction
unittestRunTest('testColorRampRenderFocus')


