include <unittest.bare>


# Start coverage
unittestCoverageStart()

# Test includes
include 'testColorRamp.bare'

# Stop coverage
unittestCoverageStop()

# Test report
return unittestReport({ \
    'coverageExclude': ['runTests.bare'], \
    'coverageMin': 100 \
})
